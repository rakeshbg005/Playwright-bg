{
  "cucumber.features": [
    "tests/UI_Test/feature/**/*.feature",
    "**/.feature"
  ],
  "cucumber.glue": [
    "tests/UI_Test/steps/**/*.ts",
    "tests/UI_Test/steps/**/*.js"
  ],
  "cucumberautocomplete.steps": [
    "tests/UI_Test/steps/*.steps.ts"
  ],
  "editor.formatOnSave": true,
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true
  }
}