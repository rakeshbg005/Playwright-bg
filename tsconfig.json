{
    "compilerOptions": {
        "target": "ES2020",
        "module": "Node16",
        "moduleResolution": "node16",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "tests/**/*.ts",
        "tests/**/*.tsx",
        "src/**/*.ts",
        "**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "playwright-report",
        "allure-results"
    ]
}